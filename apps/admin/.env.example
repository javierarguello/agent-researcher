# Base URL of the agent-researcher API (no trailing slash).
VITE_API_BASE_URL=https://agent-researcher-dev-api-xxxxx.run.app

# The admin app's Google OAuth client id (must match the `admin` app doc's
# googleClientId in Firestore). Used to obtain a Google id_token for login.
VITE_ADMIN_GOOGLE_CLIENT_ID=1234567890-abcdefg.apps.googleusercontent.com

# The admin app's Firestore doc id (well-known slug).
VITE_ADMIN_APP_ID=admin
