# ---------------------------------------------------------------------------
# agent-researcher — environment configuration
# Copy to .env for local dev. On Cloud Run these are set as service/job env vars.
# ---------------------------------------------------------------------------

# --- Environment -----------------------------------------------------------
# "dev" | "prod" — names every stateful resource (bucket, Firestore DB, SAs,
# Cloud Run service/job) so the two environments never collide.
ENV=dev

# --- GCP / Vertex ----------------------------------------------------------
# Same GCP project as home-assistant for both environments.
GCP_PROJECT_ID=sinuous-canto-497518-h7
GCP_LOCATION=us-central1

# Defaults derive from ENV; override only if you need custom names.
# Cloud Storage bucket for research outputs (researchs/{jobId}/**).
RESEARCH_BUCKET=agent-researcher-dev-reports
# Named Firestore database (one per environment).
FIRESTORE_DATABASE=agent-researcher-dev

# --- AI models (pluggable, per-agent) --------------------------------------
# Default provider; "claude" later via the same LlmProvider interface.
LLM_PROVIDER=gemini-vertex
# Concrete models behind the model-registry aliases. Agents reference ALIASES
# ('gather','flash','pro', later 'claude-sonnet') — never these ids directly —
# so swapping a model/provider never touches a template or agent.
LLM_MODEL_FLASH=gemini-2.5-flash
LLM_MODEL_PRO=gemini-2.5-pro
# Default aliases for an agent's research loop vs. structured synthesis.
LLM_DEFAULT_GATHER=gather
LLM_DEFAULT_SYNTH=pro
# Upper bound for structured JSON output (avoids mid-JSON truncation).
LLM_MAX_OUTPUT_TOKENS=16384
# Max agents running concurrently per job (Vertex quota guard; 429s are common
# on this project — keep low, the provider also retries with backoff).
LLM_MAX_CONCURRENT_AGENTS=2

# --- Web search ------------------------------------------------------------
# Priority: Brave > Tavily > DuckDuckGo (keyless fallback).
# Leave both empty to use the keyless DuckDuckGo fallback.
BRAVE_API_KEY=
TAVILY_API_KEY=

# Max web-search turns per research job (bounds cost + runtime).
RESEARCH_MAX_TURNS=16

# --- Worker triggering (API -> Cloud Run Job) ------------------------------
# Name of the Cloud Run Job the API triggers (defaults to agent-researcher-${ENV}-worker).
WORKER_JOB_NAME=agent-researcher-dev-worker
# Region the worker job runs in (usually == GCP_LOCATION).
WORKER_JOB_REGION=us-central1

# --- Signed URLs -----------------------------------------------------------
# Minutes a read-only signed URL stays valid when a job is polled as done.
SIGNED_URL_TTL_MINUTES=60

# --- API server ------------------------------------------------------------
PORT=8080
LOG_LEVEL=info
# "local" disables API-key auth for local dev. Use "production" on Cloud Run.
# API keys are managed in the Firestore `apps` collection (see `npm run apps`),
# NOT via env. Seed the base admin app with: npm run apps -- seed-admin
APP_ENV=production

# Transactional email (Postmark). Per-app From address is set on the app record in Firestore.
POSTMARK_SERVER_TOKEN=
POSTMARK_MESSAGE_STREAM=outbound
